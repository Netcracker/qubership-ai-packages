{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "configMigration": true,
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "internalChecksFilter": "strict",
  "platformAutomerge": true,
  "prCreation": "not-pending",
  "customManagers": [
    {
      "description": "Update APM dependencies pinned to GitHub release tags.",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apm\\.yml$/"
      ],
      "matchStrings": [
        "(?<depPrefix>-\\s+)(?<depName>(?<packageName>[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)/(?<apmSubdir>[^\\s#@]+))@(?<currentValue>v?\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9_.-]+)?)(?<depSuffix>\\s*(?:#.*)?)"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "depTypeTemplate": "apm"
    },
    {
      "description": "Pin and update APM dependencies that reference Git refs.",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apm\\.yml$/"
      ],
      "matchStrings": [
        "(?<indentation>[\\t ]*)-\\s+(?<depName>(?<packageName>[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)/(?<apmSubdir>[^\\s#@]+))#(?:(?<currentDigest>[0-9a-f]{40})\\s+#\\s+)?(?<currentValue>[A-Za-z_./-][A-Za-z0-9_./-]*)"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{{packageName}}}.git",
      "depTypeTemplate": "apm",
      "autoReplaceStringTemplate": "{{{indentation}}}- {{{depName}}}#{{{newDigest}}}  # {{{currentValue}}}"
    },
    {
      "description": "Update marketplace APM package entries pinned to immutable Git refs.",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)apm\\.yml$/"
      ],
      "matchStrings": [
        "(?<depPrefix>-[^\\S\\n]+name:[^\\S\\n]+[^\\n]+\\n[^\\S\\n]+source:[^\\S\\n]+(?<packageName>[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)\\n[^\\S\\n]+subdir:[^\\S\\n]+(?<apmSubdir>[^\\n]+)\\n[^\\S\\n]+ref:[^\\S\\n]+)(?<currentDigest>[0-9a-f]{40})\\s+#\\s+(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "{{{packageName}}}/{{{apmSubdir}}}",
      "packageNameTemplate": "https://github.com/{{{packageName}}}.git",
      "depTypeTemplate": "apm"
    },
    {
      "description": "Update the Python runtime used by uvx commands.",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Makefile$/",
        "/\\.sh$/"
      ],
      "matchStrings": [
        "uvx --python (?<currentValue>\\d+\\.\\d+)"
      ],
      "depNameTemplate": "python",
      "datasourceTemplate": "python-version",
      "versioningTemplate": "python"
    }
  ],
  "packageRules": [
    {
      "description": "Group APM package updates together.",
      "groupName": "apm packages",
      "matchDepTypes": [
        "apm"
      ],
      "labels": [
        "dependencies",
        "apm"
      ],
      "pinDigests": true
    },
    {
      "description": "Automerge low-risk dependency maintenance after CI is green.",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "description": "Keep GitHub Actions grouped and pinned to immutable SHAs.",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions",
      "pinDigests": true
    },
    {
      "description": "Keep CI Python tools from requirements.txt grouped together.",
      "matchManagers": [
        "pip_requirements"
      ],
      "matchFileNames": [
        "requirements.txt"
      ],
      "groupName": "python ci tools"
    },
    {
      "description": "Do not automerge APM package updates because marketplace.json is generated separately.",
      "matchDepTypes": [
        "apm"
      ],
      "automerge": false
    }
  ]
}
